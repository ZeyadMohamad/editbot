{
  "description": "Registry of all available tools in the system. Add new tools here when created.",
  "version": "1.0.0",
  "tools": {
    "extract_audio": {
      "name": "Extract Audio",
      "description": "Extract audio track from video file for processing",
      "module": "tools.ffmpeg_tool",
      "class": "FFmpegTool",
      "method": "extract_audio",
      "category": "audio",
      "inputs": {
        "video_path": {
          "type": "file",
          "required": true,
          "description": "Path to input video"
        },
        "output_path": {
          "type": "file",
          "required": true,
          "description": "Path for output audio"
        },
        "sample_rate": {
          "type": "int",
          "required": false,
          "default": 16000
        },
        "audio_format": {
          "type": "string",
          "required": false,
          "default": "wav"
        }
      },
      "outputs": {
        "audio_file": {
          "type": "file",
          "description": "Extracted audio file"
        }
      },
      "depends_on": [],
      "config_files": [
        "ffmpeg_settings.json",
        "supported_formats.json"
      ]
    },
    "get_video_info": {
      "name": "Get Video Info",
      "description": "Get video metadata like duration, resolution, fps",
      "module": "tools.ffmpeg_tool",
      "class": "FFmpegTool",
      "method": "get_video_info",
      "category": "utility",
      "inputs": {
        "video_path": {
          "type": "file",
          "required": true,
          "description": "Path to video file"
        }
      },
      "outputs": {
        "duration": {
          "type": "float",
          "description": "Video duration in seconds"
        },
        "width": {
          "type": "int",
          "description": "Video width"
        },
        "height": {
          "type": "int",
          "description": "Video height"
        },
        "fps": {
          "type": "float",
          "description": "Frames per second"
        }
      },
      "depends_on": [],
      "config_files": [
        "supported_formats.json"
      ]
    },
    "transcribe": {
      "name": "Transcribe Audio",
      "description": "Transcribe audio to text with timestamps using Whisper",
      "module": "tools.whisperx_tool",
      "class": "WhisperXTool",
      "method": "transcribe",
      "category": "transcription",
      "inputs": {
        "audio_path": {
          "type": "file",
          "required": true,
          "description": "Path to audio file"
        },
        "language": {
          "type": "string",
          "required": false,
          "default": "auto",
          "description": "Language code or 'auto'"
        }
      },
      "outputs": {
        "text": {
          "type": "string",
          "description": "Full transcribed text"
        },
        "language": {
          "type": "string",
          "description": "Detected language"
        },
        "segments": {
          "type": "array",
          "description": "Transcript segments with timestamps"
        }
      },
      "depends_on": [
        "extract_audio"
      ],
      "config_files": [
        "supported_languages.json"
      ]
    },
    "align_words": {
      "name": "Align Words",
      "description": "Get word-level timestamps from transcription",
      "module": "tools.whisperx_tool",
      "class": "WhisperXTool",
      "method": "align_words",
      "category": "transcription",
      "inputs": {
        "transcription_result": {
          "type": "object",
          "required": true,
          "description": "Result from transcribe tool"
        }
      },
      "outputs": {
        "words": {
          "type": "array",
          "description": "Words with start/end timestamps"
        }
      },
      "depends_on": [
        "transcribe"
      ],
      "config_files": []
    },
    "generate_captions": {
      "name": "Generate Captions",
      "description": "Generate ASS subtitle file with styled captions",
      "module": "tools.captions_tool",
      "class": "CaptionsTool",
      "method": "generate_ass_file",
      "category": "captions",
      "inputs": {
        "words": {
          "type": "array",
          "required": true,
          "description": "Words with timestamps"
        },
        "output_path": {
          "type": "file",
          "required": true,
          "description": "Output ASS file path"
        },
        "style": {
          "type": "object",
          "required": false,
          "description": "Caption style configuration"
        },
        "highlight_options": {
          "type": "object",
          "required": false,
          "description": "Optional layered highlight configuration (enabled, highlight_type=word_by_word|progressive, colors, bold, box)"
        },
        "detected_language": {
          "type": "string",
          "required": false,
          "description": "Detected language code, optional"
        }
      },
      "outputs": {
        "ass_file": {
          "type": "file",
          "description": "Generated ASS subtitle file"
        }
      },
      "depends_on": [
        "align_words"
      ],
      "config_files": [
        "fonts.json",
        "colors.json",
        "highlight_styles.json",
        "text_styles.json",
        "positions.json"
      ]
    },
    "render_subtitles": {
      "name": "Render Subtitles",
      "description": "Burn subtitles onto video",
      "module": "tools.ffmpeg_tool",
      "class": "FFmpegTool",
      "method": "render_subtitles",
      "category": "video",
      "inputs": {
        "video_path": {
          "type": "file",
          "required": true,
          "description": "Input video path"
        },
        "subtitle_path": {
          "type": "file",
          "required": true,
          "description": "ASS subtitle file path"
        },
        "output_path": {
          "type": "file",
          "required": true,
          "description": "Output video path"
        },
        "codec": {
          "type": "string",
          "required": false,
          "default": "libx264"
        },
        "preset": {
          "type": "string",
          "required": false,
          "default": "medium"
        },
        "crf": {
          "type": "int",
          "required": false,
          "default": 23
        }
      },
      "outputs": {
        "video_file": {
          "type": "file",
          "description": "Video with burned-in subtitles"
        }
      },
      "depends_on": [
        "generate_captions"
      ],
      "config_files": [
        "ffmpeg_settings.json",
        "supported_formats.json"
      ]
    },
    "apply_transitions": {
      "name": "Apply Transitions",
      "description": "Combine multiple clips using FFmpeg xfade transitions",
      "module": "tools.ffmpeg_tool",
      "class": "FFmpegTool",
      "method": "apply_transitions",
      "category": "video",
      "inputs": {
        "clips": {
          "type": "array",
          "required": false,
          "description": "Ordered list of clips. Each item can be a path string or {path,start_time,end_time,duration}. Required if segments is not provided."
        },
        "segments": {
          "type": "array",
          "required": false,
          "description": "Optional list of segments for a single source clip. Each item can be {start_time,end_time,duration} with optional path."
        },
        "source_path": {
          "type": "file",
          "required": false,
          "description": "Default clip path to use when segments or clip items omit path."
        },
        "transitions": {
          "type": "array",
          "required": false,
          "description": "Optional list of transitions between clips. Each item can be a string or {name/code,duration}"
        },
        "transition_duration": {
          "type": "float",
          "required": false,
          "default": 1.0,
          "description": "Default transition duration (seconds) when not specified per transition"
        },
        "output_path": {
          "type": "file",
          "required": true,
          "description": "Output video path"
        },
        "codec": {
          "type": "string",
          "required": false,
          "default": "libx264"
        },
        "preset": {
          "type": "string",
          "required": false,
          "default": "medium"
        },
        "crf": {
          "type": "int",
          "required": false,
          "default": 23
        }
      },
      "outputs": {
        "video_file": {
          "type": "file",
          "description": "Output video with transitions"
        }
      },
      "depends_on": [],
      "config_files": [
        "transitions.json",
        "ffmpeg_settings.json",
        "supported_formats.json"
      ]
    },
    "rotate_media": {
      "name": "Rotate Media",
      "description": "Rotate a single video or image by clockwise degrees and save output",
      "module": "tools.rotate_tool",
      "class": "RotateTool",
      "method": "rotate_media",
      "category": "video",
      "inputs": {
        "input_path": {
          "type": "file",
          "required": true,
          "description": "Path to input video or image"
        },
        "output_path": {
          "type": "file",
          "required": true,
          "description": "Path for rotated output media"
        },
        "rotation_cw_deg": {
          "type": "any",
          "required": true,
          "description": "Clockwise rotation in degrees, or text like 'rotate left 2 times'"
        },
        "codec": {
          "type": "string",
          "required": false,
          "default": "libx264"
        },
        "preset": {
          "type": "string",
          "required": false,
          "default": "medium"
        },
        "crf": {
          "type": "int",
          "required": false,
          "default": 23
        }
      },
      "outputs": {
        "media_file": {
          "type": "file",
          "description": "Rotated media output"
        }
      },
      "depends_on": [],
      "config_files": [
        "supported_formats.json",
        "ffmpeg_settings.json"
      ]
    },
    "stock_footage": {
      "name": "Stock Footage",
      "description": "Overlay or insert stock videos/images into a base video",
      "module": "tools.stock_footage_tool",
      "class": "StockFootageTool",
      "method": "apply_stock_footage",
      "category": "video",
      "inputs": {
        "video_path": {
          "type": "file",
          "required": true,
          "description": "Path to base video"
        },
        "stock_items": {
          "type": "array",
          "required": true,
          "description": "List of stock items with path, mode, and timing"
        },
        "output_path": {
          "type": "file",
          "required": true,
          "description": "Output video path"
        },
        "codec": {
          "type": "string",
          "required": false,
          "default": "libx264"
        },
        "preset": {
          "type": "string",
          "required": false,
          "default": "medium"
        },
        "crf": {
          "type": "int",
          "required": false,
          "default": 23
        }
      },
      "outputs": {
        "video_file": {
          "type": "file",
          "description": "Video with stock footage"
        }
      },
      "depends_on": [],
      "config_files": [
        "supported_formats.json"
      ]
    },
    "silence_cutter": {
      "name": "Silence Cutter",
      "description": "Detect silence and filler words, produce cut list and optionally trimmed media",
      "module": "tools.silence_cutter_tool",
      "class": "SilenceCutterTool",
      "method": "cut_silence",
      "category": "audio",
      "inputs": {
        "audio_path": {
          "type": "file",
          "required": true,
          "description": "Path to extracted WAV audio"
        },
        "video_path": {
          "type": "file",
          "required": false,
          "description": "Optional input video path"
        },
        "output_path": {
          "type": "file",
          "required": false,
          "description": "Output trimmed video path"
        },
        "output_audio_path": {
          "type": "file",
          "required": false,
          "description": "Output trimmed audio path"
        },
        "threshold_db": {
          "type": "float",
          "required": false,
          "default": -35.0
        },
        "min_silence_duration": {
          "type": "float",
          "required": false,
          "default": 0.3
        },
        "padding": {
          "type": "float",
          "required": false,
          "default": 0.05
        },
        "chunk_ms": {
          "type": "int",
          "required": false,
          "default": 30
        },
        "filler_detection": {
          "type": "bool",
          "required": false,
          "default": true
        },
        "filler_model_size": {
          "type": "string",
          "required": false,
          "default": "small"
        },
        "filler_language": {
          "type": "string",
          "required": false,
          "default": "auto"
        },
        "filler_confidence": {
          "type": "float",
          "required": false,
          "default": 0.5
        },
        "filler_aggressive": {
          "type": "bool",
          "required": false,
          "default": false
        },
        "manual_cut_segments": {
          "type": "array",
          "required": false,
          "description": "List of manual cut ranges {start,end} in seconds. If provided, overrides auto detection."
        }
      },
      "outputs": {
        "cut_list_path": {
          "type": "file",
          "description": "JSON cut list"
        },
        "output_video_path": {
          "type": "file",
          "description": "Trimmed video"
        },
        "output_audio_path": {
          "type": "file",
          "description": "Trimmed audio"
        }
      },
      "depends_on": [
        "extract_audio"
      ],
      "config_files": [
        "silence_cutter.json",
        "supported_formats.json",
        "supported_languages.json"
      ]
    },
    "text_overlay": {
      "name": "Text Overlay",
      "description": "Add styled text overlays with animations to video",
      "module": "tools.text_overlay_tool",
      "class": "TextOverlayTool",
      "method": "add_text",
      "category": "video",
      "inputs": {
        "video_path": {
          "type": "file",
          "required": true,
          "description": "Path to input video"
        },
        "output_path": {
          "type": "file",
          "required": false,
          "description": "Output video path"
        },
        "text": {
          "type": "string",
          "required": false,
          "description": "Simple text content"
        },
        "text_segments": {
          "type": "array",
          "required": false,
          "description": "Rich text segments with individual formatting"
        },
        "start_time": {
          "type": "float",
          "required": false,
          "default": 0.0
        },
        "end_time": {
          "type": "float",
          "required": false
        },
        "duration": {
          "type": "float",
          "required": false
        },
        "font": {
          "type": "string",
          "required": false,
          "default": "Montserrat ExtraBold"
        },
        "font_size": {
          "type": "int",
          "required": false,
          "default": 48
        },
        "color": {
          "type": "string",
          "required": false,
          "default": "FFFFFF"
        },
        "position": {
          "type": "any",
          "required": false,
          "default": "center"
        },
        "background_color": {
          "type": "string",
          "required": false
        },
        "animation_in": {
          "type": "string",
          "required": false,
          "default": "fade"
        },
        "animation_out": {
          "type": "string",
          "required": false,
          "default": "fade"
        }
      },
      "outputs": {
        "video_file": {
          "type": "file",
          "description": "Video with text overlay"
        },
        "ass_file": {
          "type": "file",
          "description": "Generated ASS subtitle file"
        }
      },
      "depends_on": [],
      "config_files": [
        "fonts.json",
        "colors.json",
        "positions.json"
      ]
    },
    "background_audio": {
      "name": "Background Audio",
      "description": "Add background music or sound effects with volume control, ducking, and fades",
      "module": "tools.background_audio_tool",
      "class": "BackgroundAudioTool",
      "method": "add_background_audio",
      "category": "audio",
      "inputs": {
        "video_path": {
          "type": "file",
          "required": true,
          "description": "Path to input video"
        },
        "audio_path": {
          "type": "file",
          "required": true,
          "description": "Path to background audio file"
        },
        "output_path": {
          "type": "file",
          "required": false,
          "description": "Output video path"
        },
        "mode": {
          "type": "string",
          "required": false,
          "default": "overlay",
          "description": "insert or overlay"
        },
        "background_volume": {
          "type": "float",
          "required": false,
          "default": 0.3
        },
        "original_volume": {
          "type": "float",
          "required": false,
          "default": 1.0
        },
        "ducking": {
          "type": "object",
          "required": false,
          "description": "Ducking configuration for overlay mode"
        },
        "fade_in_duration": {
          "type": "float",
          "required": false,
          "default": 1.0
        },
        "fade_out_duration": {
          "type": "float",
          "required": false,
          "default": 2.0
        },
        "loop": {
          "type": "bool",
          "required": false,
          "default": false
        }
      },
      "outputs": {
        "video_file": {
          "type": "file",
          "description": "Video with background audio"
        }
      },
      "depends_on": [],
      "config_files": [
        "supported_formats.json"
      ]
    },
    "image_overlay": {
      "name": "Image Overlay",
      "description": "Add images to video with position, animation, borders, and effects",
      "module": "tools.image_overlay_tool",
      "class": "ImageOverlayTool",
      "method": "add_images",
      "category": "video",
      "inputs": {
        "video_path": {
          "type": "file",
          "required": true,
          "description": "Path to input video"
        },
        "output_path": {
          "type": "file",
          "required": false,
          "description": "Output video path"
        },
        "images": {
          "type": "array",
          "required": true,
          "description": "List of images with path, timing, position, size, and effects"
        },
        "codec": {
          "type": "string",
          "required": false,
          "default": "libx264"
        },
        "preset": {
          "type": "string",
          "required": false,
          "default": "medium"
        },
        "crf": {
          "type": "int",
          "required": false,
          "default": 23
        }
      },
      "outputs": {
        "video_file": {
          "type": "file",
          "description": "Video with image overlays"
        }
      },
      "depends_on": [],
      "config_files": [
        "supported_formats.json"
      ]
    },
    "image_to_video": {
      "name": "Image to Video",
      "description": "Convert a static image into a video with configurable duration and resolution",
      "module": "tools.image_to_video_tool",
      "class": "ImageToVideoTool",
      "method": "convert",
      "category": "video",
      "inputs": {
        "image_path": {
          "type": "file",
          "required": true,
          "description": "Path to source image"
        },
        "output_path": {
          "type": "file",
          "required": false,
          "description": "Output video path"
        },
        "duration": {
          "type": "float",
          "required": false,
          "default": 10.0,
          "description": "Video duration in seconds"
        },
        "width": {
          "type": "int",
          "required": false,
          "description": "Output width in pixels (default: image width)"
        },
        "height": {
          "type": "int",
          "required": false,
          "description": "Output height in pixels (default: image height)"
        },
        "fps": {
          "type": "int",
          "required": false,
          "default": 30
        },
        "add_silent_audio": {
          "type": "boolean",
          "required": false,
          "default": true
        }
      },
      "outputs": {
        "video_file": {
          "type": "file",
          "description": "Generated video from image"
        }
      },
      "depends_on": [],
      "config_files": []
    }
  },
  "categories": {
    "audio": "Audio processing tools",
    "video": "Video processing tools",
    "transcription": "Speech-to-text tools",
    "captions": "Subtitle and caption tools",
    "utility": "Utility and helper tools"
  },
  "pipelines": {
    "caption_pipeline": {
      "description": "Full pipeline for adding captions to video",
      "steps": [
        "extract_audio",
        "transcribe",
        "align_words",
        "generate_captions",
        "render_subtitles"
      ]
    },
    "silence_cut_pipeline": {
      "description": "Remove silence and filler words from a video",
      "steps": [
        "extract_audio",
        "silence_cutter"
      ]
    }
  }
}
