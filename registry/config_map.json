        "detect language"
      ],
      "intents": [
        "set_language",
        "detect_language",
        "transcribe_language"
      ]
    },
    "silence_cutter.json": {
      "keywords": [
        "silence",
        "silent",
        "pause",
        "pauses",
        "dead air",
        "remove silence",
        "cut silence",
        "trim silence",
        "remove pauses",
        "cut pauses",
        "filler",
        "filler words",
        "um",
        "uh",
        "you know",
        "يعني",
        "اممم",
        "ممم",
        "صمت",
        "سكتات",
        "فواصل",
        "ازالة الصمت",
        "إزالة الصمت",
        "cut from",
        "trim from",
        "remove from",
        "delete from",
        "cut between",
        "timestamps",
        "timestamp",
        "timecode"
      ],
      "intents": [
        "remove_silence",
        "cut_silence",
        "remove_fillers"
      ]
