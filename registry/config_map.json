{
  "description": "Maps keywords/intents to relevant config files for smart loading",
  "version": "1.0.0",
  "keyword_mapping": {
    "fonts.json": {
      "keywords": [
        "font",
        "typeface",
        "arial",
        "montserrat",
        "roboto",
        "impact",
        "comic sans",
        "georgia",
        "verdana",
        "calibri",
        "courier",
        "times new roman",
        "trebuchet",
        "open sans"
      ],
      "intents": [
        "change_font",
        "set_font",
        "font_style"
      ]
    },
    "colors.json": {
      "keywords": [
        "color",
        "colour",
        "red",
        "blue",
        "green",
        "yellow",
        "white",
        "black",
        "orange",
        "purple",
        "pink",
        "cyan",
        "magenta",
        "gold",
        "silver",
        "teal",
        "coral",
        "lime"
      ],
      "intents": [
        "change_color",
        "set_color",
        "highlight_color",
        "text_color",
        "outline_color"
      ]
    },
    "highlight_styles.json": {
      "keywords": [
        "highlight",
        "karaoke",
