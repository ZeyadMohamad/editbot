        "italic",
        "underline",
        "strikeout",
        "outline",
        "shadow",
        "size",
        "font size",
        "small",
        "medium",
        "large",
        "huge",
        "tiny"
      ],
      "intents": [
        "text_style",
        "format_text",
        "size_text"
      ]
    },
    "positions.json": {
      "keywords": [
