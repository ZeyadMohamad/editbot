  "intent_to_configs": {
    "add_captions": [
      "fonts.json",
      "colors.json",
      "highlight_styles.json",
      "text_styles.json",
      "positions.json",
      "supported_languages.json"
    ],
    "transcribe": [
      "supported_languages.json"
    ],
    "export_video": [
      "ffmpeg_settings.json",
      "supported_formats.json"
    ],
    "style_captions": [
      "fonts.json",
      "colors.json",
      "highlight_styles.json",
      "text_styles.json",
      "positions.json"
    ],
    "remove_silence": [
      "silence_cutter.json",
      "supported_formats.json",
      "supported_languages.json"
    ]
  },
  "default_configs": [
    "supported_formats.json"
  ],
  "always_load": []
}